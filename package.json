{
  "name": "livetennisapi-mcp",
  "mcpName": "io.github.livetennisapi/livetennisapi-mcp",
  "version": "1.2.2",
  "description": "MCP server for the Live Tennis API — give Claude, Cursor and other LLM agents real-time tennis scores, players and fixtures for ATP, WTA, Challenger and ITF. Odds and model win-probability tools require the PRO and ULTRA plans.",
  "keywords": [
    "mcp",
    "modelcontextprotocol",
    "model-context-protocol",
    "mcp-server",
    "claude",
    "llm",
    "ai-agent",
    "tennis",
    "tennis-api",
    "live-scores",
    "sports",
    "sports-api",
    "sports-data",
    "atp",
    "wta"
  ],
  "homepage": "https://livetennisapi.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/livetennisapi/livetennisapi-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/livetennisapi/livetennisapi-mcp/issues"
  },
  "license": "MIT",
  "author": "Live Tennis API",
  "type": "module",
  "bin": {
    "livetennisapi-mcp": "./dist/index.js",
    "livetennisapi-mcp-http": "./dist/http.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "build:mcpb": "tsup --config tsup.mcpb.config.ts",
    "pack:mcpb": "npm run build:mcpb && mcpb pack . livetennisapi-mcp.mcpb",
    "start:http": "node dist/http.js",
    "test": "node test/protocol.mjs && node test/http-isolation.mjs && node test/http-ratelimit.mjs && node test/tools-output.mjs",
    "test:isolation": "node test/http-isolation.mjs",
    "test:ratelimit": "node test/http-ratelimit.mjs",
    "test:mutation": "python3 test/mutate.py",
    "test:tools": "node test/tools-output.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.6.0",
    "livetennisapi": "^1.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
